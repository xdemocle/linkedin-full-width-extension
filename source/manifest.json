{
  "manifest_version": 3,
  "name": "LinkedIn Full Width Browser Extension",
  "version": "0.0.1",
  "icons": {
    "16": "assets/icons/favicon-16.png",
    "32": "assets/icons/favicon-32.png",
    "48": "assets/icons/favicon-48.png",
    "128": "assets/icons/favicon-128.png"
  },
  "description": "LinkedIn Full Width",
  "homepage_url": "https://github.com/xdemocle/linkedin-full-width-extension",
  "short_name": "LinkedIn Full Width",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.linkedin.com/"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src ws://localhost:9090; child-src 'self';"
  },
  "__chrome|firefox__author": "xdemocle",
  "__opera__developer": {
    "name": "xdemocle"
  },
  "__firefox__applications": {
    "gecko": {
      "id": "{754FB1AD-CC3B-4856-B6A0-7786F8CA9D17}"
    }
  },
  "__chrome__minimum_chrome_version": "88",
  "__opera__minimum_opera_version": "76",
  "action": {
    "default_icon": {
      "16": "assets/icons/favicon-16.png",
      "32": "assets/icons/favicon-32.png",
      "48": "assets/icons/favicon-48.png",
      "128": "assets/icons/favicon-128.png"
    },
    "default_title": "LinkedIn Full Width"
  },
  "background": {
    "service_worker": "js/background.bundle.js",
    "type": "module"
  }
}